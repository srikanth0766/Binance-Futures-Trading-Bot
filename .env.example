# ─────────────────────────────────────────────────────────────────────────────
# Binance Futures Testnet – Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file: cp .env.example .env
# 2. Fill in your Testnet API credentials (https://testnet.binancefuture.com)
# 3. NEVER commit the .env file – it is listed in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Required – from Binance Futures Testnet → API Management
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_SECRET_KEY=your_testnet_secret_key_here

# Optional – defaults shown below
BASE_URL=https://testnet.binancefuture.com
RECV_WINDOW=5000
LOG_LEVEL=DEBUG
